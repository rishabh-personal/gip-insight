# ─────────────────────────────────────────────────────────────────────────────
# GIP Insight — Production environment variables
# Copy this file to /opt/gip-insight/.env on the droplet and fill in values.
# NEVER commit the actual .env file to git.
# ─────────────────────────────────────────────────────────────────────────────

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/
MONGODB_DB_NAME=gip-prod

# MySQL (reached through the SSH tunnel the API creates on startup)
MYSQL_HOST=172.16.15.4
MYSQL_PORT=3306
MYSQL_USER=zwingroot
MYSQL_PASSWORD=<password>
MYSQL_MASTER_DB=zwing

# SSH Jump Host — used to tunnel both MySQL and MongoDB
SSH_HOST=jh.ginesys.one
SSH_PORT=22
SSH_USERNAME=azureuser
# Path inside the API container where the key is volume-mounted (do not change)
SSH_KEY_PATH=/run/secrets/tunnel_key

# API server
API_PORT=3001
NODE_ENV=production

# NEXT_PUBLIC_API_URL is intentionally NOT set here.
# The web container uses relative URLs (/api/...) which Next.js rewrites
# proxy to http://gip-api:3001 via the Docker internal network.

# Azure Blob Storage — for reading task input/output payloads
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=<account>;AccountKey=<key>;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER=<container-name>

# Dashboard authentication
# These three values are required for the login page to work.
# AUTH_SECRET must be a long random string — generate with: openssl rand -hex 32
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=<strong-password>
AUTH_SECRET=<openssl rand -hex 32>
